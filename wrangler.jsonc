{
  "name": "ei-trust-receipt",
  "main": "worker/index.mjs",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": true
  }
}
